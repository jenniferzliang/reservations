# Database (PostgreSQL — Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Portal authentication
PORTAL_ACCESS_CODE="change-me"
# Generate a hash: node -e "console.log(require('bcryptjs').hashSync('your-pin', 10))"

# Session signing
JWT_SECRET="generate-a-random-secret-here"

# Google OAuth (for Calendar integration — optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Public site name (shown in browser tab)
NEXT_PUBLIC_SITE_NAME="My Restaurant"
